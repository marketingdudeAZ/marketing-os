# Copy to .env and fill with YOUR OWN keys. Never commit .env. No company credentials here.

# Anthropic
ANTHROPIC_API_KEY=

# Supabase (your own personal project for the prototype)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Google Ads API (sandbox / test account for the prototype)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# PMS — left abstract until you know which PMS the pilot property uses (Yardi / RealPage / Entrata)
PMS_PROVIDER=
PMS_API_BASE_URL=
PMS_API_KEY=

# Notifications (optional)
SLACK_WEBHOOK_URL=
